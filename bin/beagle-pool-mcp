#!/usr/bin/env python3
"""MCP server that proxies Edit calls to a warm repair worker.

Agent 1 calls Edit normally. This server intercepts it, queues the edit
in memory, and dispatches it to a warm Claude worker. Agent 1 gets an
instant "ok" and moves on. The worker applies the edit and handles errors.

Usage (in --mcp-config JSON):
    {"beagle-pool": {"command": "beagle-pool-mcp", "args": ["--model", "sonnet"]}}

Then block the real Edit tool:
    --disallowedTools Edit
"""

import argparse
import asyncio
import json
import os
import subprocess
import sys
import time

try:
    from mcp.server import Server
    from mcp.server.stdio import stdio_server
    import mcp.types as types
except ImportError:
    print("error: mcp package not installed", file=sys.stderr)
    sys.exit(1)

try:
    import claude_code_sdk as sdk
    from claude_code_sdk._internal import message_parser as mp

    _orig_parse = mp.parse_message
    def _safe_parse(data):
        try:
            return _orig_parse(data)
        except Exception:
            return None
    mp.parse_message = _safe_parse
except ImportError:
    print("error: claude-code-sdk not installed", file=sys.stderr)
    sys.exit(1)

PROJECT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
PROMPT_FILE = os.path.join(PROJECT_DIR, ".beagle", "repair-agent-prompt.md")
LOG_FILE = os.path.join(PROJECT_DIR, ".beagle", "pool-log.jsonl")


def log_event(event, **kwargs):
    entry = {"ts": time.time(), "event": event, **kwargs}
    try:
        os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
        with open(LOG_FILE, "a") as f:
            f.write(json.dumps(entry) + "\n")
    except Exception:
        pass


class WarmWorker:
    def __init__(self, model, cwd):
        self.model = model
        self.cwd = cwd
        self.client = None
        self.busy = False
        self.queue = asyncio.Queue()
        self.total_cost = 0.0
        self.total_edits = 0

    async def connect(self):
        system_prompt = ""
        if os.path.exists(PROMPT_FILE):
            with open(PROMPT_FILE) as f:
                system_prompt = f.read()

        opts = sdk.ClaudeCodeOptions(
            allowed_tools=["Read", "Edit", "Bash"],
            model=self.model,
            permission_mode="bypassPermissions",
            append_system_prompt=system_prompt,
            cwd=self.cwd,
        )
        self.client = sdk.ClaudeSDKClient(opts)
        await self.client.connect()

    async def apply_edit(self, file_path, old_string, new_string):
        """Apply a single edit via the warm worker."""
        self.busy = True
        t0 = time.time()

        prompt = (
            f"Apply this edit to {file_path}:\n\n"
            f"Replace:\n```\n{old_string}\n```\n\n"
            f"With:\n```\n{new_string}\n```\n\n"
            f"Use the Edit tool. If it fails, read the file and retry. "
            f"Then run: {PROJECT_DIR}/bin/beagle-daemon query check-enriched {file_path}\n"
            f"If new type errors appear from your edit, fix them too."
        )

        cost = 0.0
        try:
            await self.client.query(prompt)
            async for msg in self.client.receive_response():
                if msg is None:
                    continue
                if isinstance(msg, sdk.ResultMessage):
                    cost = getattr(msg, "total_cost_usd", 0.0) or 0.0
                    break
            self.total_edits += 1
            self.total_cost += cost
            duration = round(time.time() - t0, 1)
            log_event("edit_applied", file=os.path.basename(file_path),
                      duration_s=duration, cost_usd=cost)
            return True
        except Exception as e:
            log_event("edit_failed", file=os.path.basename(file_path),
                      error=str(e))
            return False
        finally:
            self.busy = False

    async def run_loop(self):
        """Process edits from the queue forever."""
        while True:
            file_path, old_string, new_string = await self.queue.get()
            await self.apply_edit(file_path, old_string, new_string)

    async def disconnect(self):
        if self.client:
            try:
                await self.client.disconnect()
            except Exception:
                pass


async def run(model, cwd, max_cost):
    server = Server("beagle-pool")
    worker = WarmWorker(model, cwd)

    @server.list_tools()
    async def list_tools():
        return [
            types.Tool(
                name="Edit",
                description=(
                    "Edit a file by replacing an exact string match. "
                    "Provide file_path, old_string, and new_string."
                ),
                inputSchema={
                    "type": "object",
                    "properties": {
                        "file_path": {
                            "type": "string",
                            "description": "Absolute path to the file",
                        },
                        "old_string": {
                            "type": "string",
                            "description": "The text to find and replace",
                        },
                        "new_string": {
                            "type": "string",
                            "description": "The replacement text",
                        },
                    },
                    "required": ["file_path", "old_string", "new_string"],
                },
            )
        ]

    @server.call_tool()
    async def call_tool(name, arguments):
        if name != "Edit":
            return types.CallToolResult(
                content=[types.TextContent(type="text", text=f"Unknown tool: {name}")]
            )

        file_path = arguments.get("file_path", "")
        old_string = arguments.get("old_string", "")
        new_string = arguments.get("new_string", "")

        if worker.total_cost >= max_cost:
            return types.CallToolResult(
                content=[types.TextContent(
                    type="text",
                    text=f"Cost cap reached (${worker.total_cost:.2f}/${max_cost:.2f}). Edit queued but not applied."
                )]
            )

        # Queue the edit and return immediately
        await worker.queue.put((file_path, old_string, new_string))
        log_event("edit_queued", file=os.path.basename(file_path),
                  queue_size=worker.queue.qsize())

        return types.CallToolResult(
            content=[types.TextContent(
                type="text",
                text=f"Edit queued for {os.path.basename(file_path)}. "
                     f"The executor will apply it. Move on to the next diagnosis."
            )]
        )

    # Connect warm worker
    log_event("pool_mcp_start", model=model, cwd=cwd, max_cost=max_cost)
    await worker.connect()
    log_event("worker_connected")

    # Start worker loop in background
    worker_task = asyncio.create_task(worker.run_loop())

    try:
        async with stdio_server() as (read_stream, write_stream):
            await server.run(read_stream, write_stream,
                           server.create_initialization_options())
    finally:
        worker_task.cancel()
        await worker.disconnect()
        log_event("pool_mcp_stop", total_edits=worker.total_edits,
                  total_cost=worker.total_cost)


def main():
    parser = argparse.ArgumentParser(description="MCP Edit proxy + warm pool")
    parser.add_argument("--model", default="sonnet")
    parser.add_argument("--cwd", default=os.getcwd())
    parser.add_argument("--max-cost", type=float, default=2.00)
    args = parser.parse_args()

    asyncio.run(run(args.model, args.cwd, args.max_cost))


if __name__ == "__main__":
    main()
