#!/usr/bin/env bash
# beagle-op-run: evaluate a beagle source file via the operative interpreter.
#
# Usage:
#   bin/beagle-op-run <source.b*>
#
# Reads source, evaluates each form against the operative evaluator
# (bootstrap + standard forms loaded). Prints the value of the last form.

set -euo pipefail
source "$(dirname "$0")/_beagle-racket"

if [[ $# -ne 1 ]]; then
    echo "usage: beagle-op-run <source>" >&2
    exit 2
fi

src="$1"
if [[ ! -f "$src" ]]; then
    echo "beagle-op-run: file not found: $src" >&2
    exit 1
fi

"$RACKET" -e "
(require beagle/private/pipeline)
(define v (run-source (vector-ref (current-command-line-arguments) 0)))
(unless (void? v) (writeln v))
" -- "$src"
