#lang beagle

(ns beagle.e19.router-v2)

(define-macro proc defrouter
  [(name : Symbol) (routes : (Vec Syntax))] : (Vec Form)
  (let* ((route-items (if (and (pair? routes) (eq? (car routes) BRACKET-TAG))
                          (cdr routes)
                          routes))
         (dispatch-name (string->symbol (format "~a-dispatch" name)))
         (log-name (string->symbol (format "~a-log" name)))
         (cond-pairs
          (append
           (apply append
                  (map (lambda (r)
                         (let ((method (car r))
                               (path (cadr r))
                               (handler (caddr r)))
                           (list (list 'and (list '= 'method method) (list '= 'path path))
                                 (symbol->string handler))))
                       route-items))
           (list 'true "404 Not Found"))))
    (list
     `(defn ,dispatch-name ,(br '(method : String) '(path : String)) : String
        (cond ,@(let loop ((items cond-pairs) (acc '()))
                  (if (null? items) (reverse acc)
                      (loop (cddr items)
                            (cons (br (car items) (cadr items)) acc))))))
     `(defn ,log-name ,(br '(method : String) '(path : String)) : String
        (do (println (str "[LOG] " method " " path))
            (,dispatch-name method path))))))

(defrouter api
  [("GET" "/users" handle-users)
   ("POST" "/users" create-user)
   ("GET" "/products" handle-products)])

(defn handle-users [] : String "handle-users")
(defn create-user [] : String "create-user")
(defn handle-products [] : String "handle-products")

(println (str "GET /users -> " (api-dispatch "GET" "/users")))
(println (str "POST /users -> " (api-dispatch "POST" "/users")))
(println (str "DELETE /users -> " (api-dispatch "DELETE" "/users")))
(println (api-log "POST" "/users"))
