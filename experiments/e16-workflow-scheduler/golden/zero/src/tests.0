        resource_count: 0, resources: fill_resources_0()
    }
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_validated_two_task() -> TestResult {
    let mut input = make_input_2t1w(
        make_simple_task(1, 10, 1), make_simple_task(2, 5, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

fun run_validated_dep_chain() -> TestResult {
    let mut input = make_input_2t1w(
        make_simple_task(1, 10, 1), make_task_with_dep(2, 5, 1, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

fun run_validated_caps() -> TestResult {
    let mut input = make_input_1t1w(
        make_task_with_caps(1, 10, 1, 42), make_worker_with_cap(100, 42))
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

fun run_validated_unavail() -> TestResult {
    let mut input = make_input_1t1w(
        make_simple_task(1, 5, 1), make_worker_with_unavail(100, 0, 10))
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

fun run_validated_parallel() -> TestResult {
    let mut input = make_input_2t2w(
        make_simple_task(1, 10, 1), make_simple_task(2, 5, 1),
        make_simple_worker(100), make_simple_worker(101))
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

fun run_validated_resource() -> TestResult {
    let mut input = ScheduleInput {
        task_count: 2,
        tasks: fill_tasks_2(
            make_task_with_resource(1, 10, 1, 500),
            make_task_with_resource(2, 10, 1, 500)),
        worker_count: 2,
        workers: fill_workers_2(make_simple_worker(100), make_simple_worker(101)),
        resource_count: 1,
        resources: fill_resources_1(Resource { id: 500, capacity: 1 })
    }
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

// ===========================================================================
// Group 1: Passing unit tests (direct runner can evaluate these)
// ===========================================================================

test "RetryPolicy construction" {
    let r = RetryPolicy { max_attempts: 3, backoff: 5 }
    expect(r.max_attempts == 3)
    expect(r.backoff == 5)
}

test "Window construction" {
    let w = Window { start: 10, end: 20 }
    expect(w.start == 10)
    expect(w.end == 20)
}

test "Resource construction" {
    let r = Resource { id: 42, capacity: 3 }
    expect(r.id == 42)
    expect(r.capacity == 3)
}

test "Assignment default has zero fields" {
    let a = default_asgn()
    expect(a.task_id == 0)
    expect(a.worker_id == 0)
    expect(a.start_time == 0)
    expect(a.end_time == 0)
    expect(a.attempt == 0)
}

test "Assignment construction" {
    let a = Assignment { task_id: 1, worker_id: 100, start_time: 5, end_time: 15, attempt: 2 }
    expect(a.task_id == 1)
    expect(a.worker_id == 100)
    expect(a.start_time == 5)
    expect(a.end_time == 15)
    expect(a.attempt == 2)
}

test "TestResult shape construction" {
    let r = TestResult {
        ok: true, assignment_count: 1, failure_count: 0,
        first_task_id: 1, first_worker_id: 100, first_start: 0,
        first_end: 10, first_attempt: 1, second_task_id: 0,
        second_start: 0, second_end: 0, third_task_id: 0,
        third_start: 0, violation_count: 0
    }
    expect(r.ok == true)
    expect(r.assignment_count == 1)
    expect(r.first_task_id == 1)
}

test "compute_max_slide: no deadline" {
    let result = compute_max_slide(0, 0, 10)
    expect(result == 1440)
}

test "compute_max_slide: with deadline" {
    let result = compute_max_slide(0, 50, 10)
    expect(result == 40)
}

test "compute_max_slide: deadline allows more than default" {
    let result = compute_max_slide(0, 2000, 10)
    expect(result == 1440)
}

test "should_swap: different starts" {
    expect(should_swap(10, 1, 5, 2) == true)
    expect(should_swap(5, 1, 10, 2) == false)
}

test "should_swap: same start, higher task id" {
    expect(should_swap(5, 10, 5, 3) == true)
    expect(should_swap(5, 3, 5, 10) == false)
}

test "should_swap: equal start and task" {
    expect(should_swap(5, 5, 5, 5) == false)
}

// ===========================================================================
// Group 2: Integration tests (xfail — require while/array/ref support)
//
// Each test calls a scenario runner that internally builds
// ScheduleInput, invokes schedule(), and returns a TestResult.
// The assertions check the scalar fields of TestResult.
// ===========================================================================

// --- Happy path ---

test "xfail: empty input produces ok with no assignments" {
    let r = run_empty_input()
    expect(r.ok == true)
    expect(r.assignment_count == 0)
    expect(r.failure_count == 0)
}

test "xfail: single task assigned to single worker" {
    let r = run_single_task()
    expect(r.ok == true)
    expect(r.assignment_count == 1)
    expect(r.first_task_id == 1)
    expect(r.first_worker_id == 100)
    expect(r.first_start == 0)
    expect(r.first_end == 10)
    expect(r.first_attempt == 1)
}

test "xfail: zero-duration task scheduled at time 0" {
    let r = run_zero_duration()
    expect(r.ok == true)
    expect(r.assignment_count == 1)
    expect(r.first_start == 0)
    expect(r.first_end == 0)
}

test "xfail: two tasks one worker run sequentially" {
    let r = run_two_tasks_sequential()
    expect(r.ok == true)
    expect(r.assignment_count == 2)
    expect(r.first_task_id == 1)
    expect(r.first_start == 0)
    expect(r.first_end == 10)
    expect(r.second_task_id == 2)
    expect(r.second_start == 10)
    expect(r.second_end == 15)
}

test "xfail: two tasks two workers run in parallel" {
    let r = run_two_tasks_parallel()
    expect(r.ok == true)
    expect(r.assignment_count == 2)
    expect(r.first_start == 0)
    expect(r.second_start == 0)
}

// --- Priority ---

test "xfail: lower priority number scheduled first" {
    let r = run_priority_ordering()
    expect(r.ok == true)
    expect(r.first_task_id == 2)
    expect(r.first_start == 0)
    expect(r.second_task_id == 1)
    expect(r.second_start == 10)
}

test "xfail: same priority tie broken by task id" {
    let r = run_priority_tie_by_id()
    expect(r.ok == true)
    expect(r.first_task_id == 3)
    expect(r.first_start == 0)
    expect(r.second_task_id == 10)
    expect(r.second_start == 5)
}

// --- Dependencies ---

test "xfail: dependency chain B depends on A" {
    let r = run_dep_chain()
    expect(r.ok == true)
    expect(r.assignment_count == 2)
    expect(r.first_task_id == 1)
    expect(r.first_end == 10)
    expect(r.second_task_id == 2)
    expect(r.second_start == 10)
    expect(r.second_end == 15)
}

test "xfail: three-task linear chain" {
    let r = run_three_task_chain()
    expect(r.ok == true)
    expect(r.assignment_count == 3)
    expect(r.first_start == 0)
    expect(r.second_start == 5)
    expect(r.third_start == 10)
}

test "xfail: diamond dependency C waits for both A and B" {
    let r = run_diamond_dep()
    expect(r.ok == true)
    expect(r.assignment_count == 3)
    expect(r.third_start >= 10)
}

test "xfail: dependency overrides priority" {
    let r = run_dep_overrides_priority()
    expect(r.ok == true)
    expect(r.first_task_id == 1)
    expect(r.first_start == 0)
    expect(r.second_task_id == 2)
    expect(r.second_start >= 10)
}

// --- Cycle detection ---

test "xfail: two-task cycle detected" {
    let r = run_two_task_cycle()
    expect(r.ok == false)
    expect(r.failure_count > 0)
}

test "xfail: three-task cycle detected" {
    let r = run_three_task_cycle()
    expect(r.ok == false)
    expect(r.failure_count > 0)
}

// --- Capabilities ---

test "xfail: task matched to capable worker" {
    let r = run_cap_match()
    expect(r.ok == true)
    expect(r.assignment_count == 1)
    expect(r.first_worker_id == 100)
}

test "xfail: worker with superset of caps is eligible" {
    let r = run_cap_superset()
    expect(r.ok == true)
    expect(r.assignment_count == 1)
}

test "xfail: no capable worker produces failure" {
    let r = run_no_capable_worker()
    expect(r.ok == false)
    expect(r.failure_count == 1)
}

test "xfail: two caps both required and present" {
    let r = run_two_caps_match()
    expect(r.ok == true)
    expect(r.assignment_count == 1)
}

test "xfail: two caps partial mismatch fails" {
    let r = run_two_caps_partial()
    expect(r.ok == false)
    expect(r.failure_count == 1)
}

test "xfail: capability routing to correct workers" {
    let r = run_cap_routing()
    expect(r.ok == true)
    expect(r.assignment_count == 2)
}

// --- Time windows ---

test "xfail: task slides past unavailability window" {
    let r = run_unavail_slide()
    expect(r.ok == true)
    expect(r.first_start >= 10)
}

test "xfail: task assigned to available worker when first busy" {
    let r = run_unavail_second_worker()
    expect(r.ok == true)
    expect(r.first_worker_id == 101)
    expect(r.first_start == 0)
}

// --- Edge cases ---

test "xfail: no workers in input fails" {
    let r = run_no_workers()
    expect(r.ok == false)
    expect(r.failure_count == 1)
}

// --- Retry ---

test "xfail: retry task first attempt succeeds" {
    let r = run_retry_success()
    expect(r.ok == true)
    expect(r.first_attempt == 1)
}

// --- Deadlines ---

test "xfail: task fits within deadline" {
    let r = run_deadline_ok()
    expect(r.ok == true)
    expect(r.first_end <= 100)
}

test "xfail: task exceeding deadline fails" {
    let r = run_deadline_fail()
    expect(r.ok == false)
    expect(r.failure_count == 1)
}

// --- Resources ---

test "xfail: resource cap 1 forces sequential" {
    let r = run_resource_sequential()
    expect(r.ok == true)
    expect(r.first_start == 0)
    expect(r.second_start >= 10)
}

test "xfail: resource cap 2 allows parallel" {
    let r = run_resource_parallel()
    expect(r.ok == true)
    expect(r.first_start == 0)
    expect(r.second_start == 0)
}

// --- Worker selection ---

test "xfail: lowest worker id chosen among eligible" {
    let r = run_lowest_worker_id()
    expect(r.ok == true)
    expect(r.first_worker_id == 101)
}

// --- Mixed success/failure ---

test "xfail: one task succeeds one fails" {
    let r = run_mixed_success_fail()
    expect(r.ok == false)
    expect(r.assignment_count == 1)
    expect(r.failure_count == 1)
}

// --- Five tasks priority ordering ---

test "xfail: five tasks in priority then id order" {
    let r = run_five_tasks_priority()
    expect(r.ok == true)
    expect(r.assignment_count == 5)
    expect(r.first_task_id == 2)
    expect(r.second_task_id == 4)
}

// --- Validator integration ---

test "xfail: validator: single task no violations" {
    let r = run_single_task_validated()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}

test "xfail: validator: two tasks no violations" {
    let r = run_validated_two_task()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}

test "xfail: validator: dep chain no violations" {
    let r = run_validated_dep_chain()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}

test "xfail: validator: caps match no violations" {
    let r = run_validated_caps()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}

test "xfail: validator: unavail avoidance no violations" {
    let r = run_validated_unavail()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}

test "xfail: validator: parallel schedule no violations" {
    let r = run_validated_parallel()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}

test "xfail: validator: resource constraint no violations" {
    let r = run_validated_resource()
    expect(r.ok == true)
    expect(r.violation_count == 0)
}
