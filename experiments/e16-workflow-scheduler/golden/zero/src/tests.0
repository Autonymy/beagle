// Verification oracle for the E16 workflow scheduler.
//
// Zero's direct-frontend test runner (v0.1.3) supports a limited AST
// subset: scalars, shapes without arrays, function calls, if/else,
// let bindings, and binary operators.  It does NOT yet support array
// literals, while loops, mutation, or ref/mutref expressions.
//
// Tests are split into two groups:
//   1. Unit tests for shape construction and simple predicates that
//      the direct runner CAN evaluate.  These pass today.
//   2. Integration tests that exercise the full scheduler, graph,
//      matcher, and validator modules.  These are prefixed "xfail:"
//      so the runner counts them as expected failures until the
//      backend gains while-loop and array support.
//
// ALL tests type-check (`zero check`) against the real API, so they
// serve as a structural oracle even before the runner can execute them.

use types
use scheduler
use graph
use matcher
use validator

// ===========================================================================
// Helper constructors (type-checked, used by xfail integration tests)
// ===========================================================================

fun empty_window() -> Window {
    return Window { start: 0, end: 0 }
}

fun make_simple_task(id: i32, duration: i32, priority: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 0, depends_on: [0, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_task_with_deadline(id: i32, duration: i32, priority: i32, deadline: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: deadline,
        cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 0, depends_on: [0, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_task_with_caps(id: i32, duration: i32, priority: i32, cap1: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 1, caps: [cap1, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 0, depends_on: [0, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_task_with_caps2(id: i32, duration: i32, priority: i32, cap1: i32, cap2: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 2, caps: [cap1, cap2, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 0, depends_on: [0, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_task_with_dep(id: i32, duration: i32, priority: i32, dep: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 1, depends_on: [dep, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_task_with_deps2(id: i32, duration: i32, priority: i32, dep1: i32, dep2: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 2, depends_on: [dep1, dep2, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_task_with_retry(id: i32, duration: i32, priority: i32, max_attempts: i32, backoff: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 0, resources: [0, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 0, depends_on: [0, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: max_attempts, backoff: backoff }
    }
}

fun make_task_with_resource(id: i32, duration: i32, priority: i32, res: i32) -> Task {
    return Task {
        id: id, duration: duration, priority: priority, deadline: 0,
        cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        resource_count: 1, resources: [res, 0, 0, 0, 0, 0, 0, 0],
        dep_count: 0, depends_on: [0, 0, 0, 0, 0, 0, 0, 0],
        retry: RetryPolicy { max_attempts: 0, backoff: 0 }
    }
}

fun make_simple_worker(id: i32) -> Worker {
    return Worker {
        id: id, cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        unavail_count: 0,
        unavail: [empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window()]
    }
}

fun make_worker_with_cap(id: i32, cap1: i32) -> Worker {
    return Worker {
        id: id, cap_count: 1, caps: [cap1, 0, 0, 0, 0, 0, 0, 0],
        unavail_count: 0,
        unavail: [empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window()]
    }
}

fun make_worker_with_caps2(id: i32, cap1: i32, cap2: i32) -> Worker {
    return Worker {
        id: id, cap_count: 2, caps: [cap1, cap2, 0, 0, 0, 0, 0, 0],
        unavail_count: 0,
        unavail: [empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window()]
    }
}

fun make_worker_with_caps3(id: i32, cap1: i32, cap2: i32, cap3: i32) -> Worker {
    return Worker {
        id: id, cap_count: 3, caps: [cap1, cap2, cap3, 0, 0, 0, 0, 0],
        unavail_count: 0,
        unavail: [empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window()]
    }
}

fun make_worker_with_unavail(id: i32, ws: i32, we: i32) -> Worker {
    return Worker {
        id: id, cap_count: 0, caps: [0, 0, 0, 0, 0, 0, 0, 0],
        unavail_count: 1,
        unavail: [Window { start: ws, end: we }, empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window(), empty_window()]
    }
}

fun et() -> Task { return make_simple_task(0, 0, 0) }
fun ew() -> Worker { return make_simple_worker(0) }
fun er() -> Resource { return Resource { id: 0, capacity: 0 } }

fun fill_tasks_1(t0: Task) -> [32]Task {
    return [t0, et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et()]
}

fun fill_tasks_2(t0: Task, t1: Task) -> [32]Task {
    return [t0, t1, et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et()]
}

fun fill_tasks_3(t0: Task, t1: Task, t2: Task) -> [32]Task {
    return [t0, t1, t2, et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et()]
}

fun fill_tasks_4(t0: Task, t1: Task, t2: Task, t3: Task) -> [32]Task {
    return [t0, t1, t2, t3, et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et()]
}

fun fill_tasks_5(t0: Task, t1: Task, t2: Task, t3: Task, t4: Task) -> [32]Task {
    return [t0, t1, t2, t3, t4, et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et(), et()]
}

fun fill_workers_1(w0: Worker) -> [16]Worker {
    return [w0, ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew()]
}

fun fill_workers_2(w0: Worker, w1: Worker) -> [16]Worker {
    return [w0, w1, ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew()]
}

fun fill_workers_3(w0: Worker, w1: Worker, w2: Worker) -> [16]Worker {
    return [w0, w1, w2, ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew(), ew()]
}

fun fill_resources_0() -> [16]Resource {
    return [er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er()]
}

fun fill_resources_1(r0: Resource) -> [16]Resource {
    return [r0, er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er(), er()]
}

fun make_input_0() -> ScheduleInput {
    return ScheduleInput {
        task_count: 0, tasks: fill_tasks_1(et()),
        worker_count: 0, workers: fill_workers_1(ew()),
        resource_count: 0, resources: fill_resources_0()
    }
}

fun make_input_1t1w(t0: Task, w0: Worker) -> ScheduleInput {
    return ScheduleInput {
        task_count: 1, tasks: fill_tasks_1(t0),
        worker_count: 1, workers: fill_workers_1(w0),
        resource_count: 0, resources: fill_resources_0()
    }
}

fun make_input_2t1w(t0: Task, t1: Task, w0: Worker) -> ScheduleInput {
    return ScheduleInput {
        task_count: 2, tasks: fill_tasks_2(t0, t1),
        worker_count: 1, workers: fill_workers_1(w0),
        resource_count: 0, resources: fill_resources_0()
    }
}

fun make_input_2t2w(t0: Task, t1: Task, w0: Worker, w1: Worker) -> ScheduleInput {
    return ScheduleInput {
        task_count: 2, tasks: fill_tasks_2(t0, t1),
        worker_count: 2, workers: fill_workers_2(w0, w1),
        resource_count: 0, resources: fill_resources_0()
    }
}

fun make_input_3t1w(t0: Task, t1: Task, t2: Task, w0: Worker) -> ScheduleInput {
    return ScheduleInput {
        task_count: 3, tasks: fill_tasks_3(t0, t1, t2),
        worker_count: 1, workers: fill_workers_1(w0),
        resource_count: 0, resources: fill_resources_0()
    }
}

fun make_input_3t2w(t0: Task, t1: Task, t2: Task, w0: Worker, w1: Worker) -> ScheduleInput {
    return ScheduleInput {
        task_count: 3, tasks: fill_tasks_3(t0, t1, t2),
        worker_count: 2, workers: fill_workers_2(w0, w1),
        resource_count: 0, resources: fill_resources_0()
    }
}

// ===========================================================================
// Integration test wrappers
//
// Each wrapper builds a ScheduleInput, calls schedule(&input), and
// returns a scalar result. The direct runner cannot evaluate these yet
// because they use while loops, arrays, and refs internally. They
// type-check, ensuring the test oracle is structurally correct.
// ===========================================================================

// Result shape for scalar extraction from ScheduleOutput
shape TestResult {
    ok: Bool,
    assignment_count: i32,
    failure_count: i32,
    first_task_id: i32,
    first_worker_id: i32,
    first_start: i32,
    first_end: i32,
    first_attempt: i32,
    second_task_id: i32,
    second_start: i32,
    second_end: i32,
    third_task_id: i32,
    third_start: i32,
    violation_count: i32,
}

fun extract_result(out: ref<ScheduleOutput>) -> TestResult {
    return TestResult {
        ok: out.ok,
        assignment_count: out.assignment_count,
        failure_count: out.failure_count,
        first_task_id: out.assignments[0].task_id,
        first_worker_id: out.assignments[0].worker_id,
        first_start: out.assignments[0].start_time,
        first_end: out.assignments[0].end_time,
        first_attempt: out.assignments[0].attempt,
        second_task_id: out.assignments[1].task_id,
        second_start: out.assignments[1].start_time,
        second_end: out.assignments[1].end_time,
        third_task_id: out.assignments[2].task_id,
        third_start: out.assignments[2].start_time,
        violation_count: 0
    }
}

fun extract_with_validation(input: ref<ScheduleInput>, out: ref<ScheduleOutput>) -> TestResult {
    let vr = validate_assignments(input, &out.assignments, out.assignment_count)
    return TestResult {
        ok: out.ok,
        assignment_count: out.assignment_count,
        failure_count: out.failure_count,
        first_task_id: out.assignments[0].task_id,
        first_worker_id: out.assignments[0].worker_id,
        first_start: out.assignments[0].start_time,
        first_end: out.assignments[0].end_time,
        first_attempt: out.assignments[0].attempt,
        second_task_id: out.assignments[1].task_id,
        second_start: out.assignments[1].start_time,
        second_end: out.assignments[1].end_time,
        third_task_id: out.assignments[2].task_id,
        third_start: out.assignments[2].start_time,
        violation_count: vr.violation_count
    }
}

// --- Scenario runners: each builds input, calls schedule, returns TestResult ---

fun run_empty_input() -> TestResult {
    let mut input = make_input_0()
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_single_task() -> TestResult {
    let mut input = make_input_1t1w(make_simple_task(1, 10, 1), make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_single_task_validated() -> TestResult {
    let mut input = make_input_1t1w(make_simple_task(1, 10, 1), make_simple_worker(100))
    let out = schedule(&input)
    return extract_with_validation(&input, &out)
}

fun run_zero_duration() -> TestResult {
    let mut input = make_input_1t1w(make_simple_task(1, 0, 1), make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_two_tasks_sequential() -> TestResult {
    let mut input = make_input_2t1w(
        make_simple_task(1, 10, 1), make_simple_task(2, 5, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_two_tasks_parallel() -> TestResult {
    let mut input = make_input_2t2w(
        make_simple_task(1, 10, 1), make_simple_task(2, 5, 1),
        make_simple_worker(100), make_simple_worker(101))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_priority_ordering() -> TestResult {
    let mut input = make_input_2t1w(
        make_simple_task(1, 10, 5), make_simple_task(2, 10, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_priority_tie_by_id() -> TestResult {
    let mut input = make_input_2t1w(
        make_simple_task(10, 5, 1), make_simple_task(3, 5, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_dep_chain() -> TestResult {
    let mut input = make_input_2t1w(
        make_simple_task(1, 10, 1), make_task_with_dep(2, 5, 1, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_three_task_chain() -> TestResult {
    let mut input = make_input_3t1w(
        make_simple_task(1, 5, 1), make_task_with_dep(2, 5, 1, 1),
        make_task_with_dep(3, 5, 1, 2), make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_diamond_dep() -> TestResult {
    let mut input = ScheduleInput {
        task_count: 3,
        tasks: fill_tasks_3(
            make_simple_task(1, 5, 1), make_simple_task(2, 10, 1),
            make_task_with_deps2(3, 5, 1, 1, 2)),
        worker_count: 2,
        workers: fill_workers_2(make_simple_worker(100), make_simple_worker(101)),
        resource_count: 0, resources: fill_resources_0()
    }
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_two_task_cycle() -> TestResult {
    let mut input = make_input_2t1w(
        make_task_with_dep(1, 5, 1, 2), make_task_with_dep(2, 5, 1, 1),
        make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_three_task_cycle() -> TestResult {
    let mut input = make_input_3t1w(
        make_task_with_dep(1, 5, 1, 3), make_task_with_dep(2, 5, 1, 1),
        make_task_with_dep(3, 5, 1, 2), make_simple_worker(100))
    let out = schedule(&input)
    return extract_result(&out)
}

fun run_cap_match() -> TestResult {
    let mut input = make_input_1t1w(
