// Entity definitions for the workflow scheduler.
// Pure data shapes, no logic. Uses fixed-capacity arrays
// since Zero does not have dynamic collections.

shape RetryPolicy {
    max_attempts: i32,
    backoff: i32,
}

shape Window {
    start: i32,
    end: i32,
}

shape Task {
    id: i32,
    duration: i32,
    priority: i32,
    deadline: i32,
    cap_count: i32,
    caps: [8]i32,
    resource_count: i32,
    resources: [8]i32,
    dep_count: i32,
    depends_on: [8]i32,
    retry: RetryPolicy,
}

shape Worker {
    id: i32,
    cap_count: i32,
    caps: [8]i32,
    unavail_count: i32,
    unavail: [8]Window,
}

shape Resource {
    id: i32,
    capacity: i32,
}

shape Assignment {
    task_id: i32,
    worker_id: i32,
    start_time: i32,
    end_time: i32,
    attempt: i32,
}

choice FailureReason {
    dependency_cycle,
    no_capable_worker,
    resource_over_capacity,
    deadline_missed,
    worker_unavailable,
}

shape ScheduleFailure {
    task_id: i32,
    reason: FailureReason,
    cycle_len: i32,
    cycle_buf: [16]i32,
    resource_idx: i32,
    capacity: i32,
    demanded: i32,
    earliest_start: i32,
    duration: i32,
    deadline: i32,
    worker_idx: i32,
}

choice ViolationKind {
    capability_mismatch,
    window_conflict,
    resource_exceeded,
    dependency_order,
    deadline_exceeded,
    overlap_violation,
}

shape Violation {
    assignment_idx: i32,
    kind: ViolationKind,
    missing_cap_count: i32,
    window_start: i32,
    window_end: i32,
    resource_idx: i32,
    at_time: i32,
    count: i32,
    capacity: i32,
    dep_task_idx: i32,
    dep_end: i32,
    task_start: i32,
    other_task_idx: i32,
    deadline: i32,
    end_time: i32,
}

shape ScheduleInput {
    task_count: i32,
    tasks: [32]Task,
    worker_count: i32,
    workers: [16]Worker,
    resource_count: i32,
    resources: [16]Resource,
}

shape ScheduleOutput {
    ok: Bool,
    assignment_count: i32,
    assignments: [32]Assignment,
    failure_count: i32,
    failures: [32]ScheduleFailure,
}
