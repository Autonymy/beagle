// Constraint verification for assignments.
// Validates all assignments post-hoc against the full constraint set.
// A correct scheduler produces zero violations.

use types
use matcher

shape ValidationResult {
    violation_count: i32,
    violations: [32]Violation
}

fun validate_assignments(input: ref<ScheduleInput>, assignments: ref<[32]Assignment>, assignment_count: i32) -> ValidationResult {
    let mut result = ValidationResult {
        violation_count: 0,
        violations: [default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol(), default_viol()]
    }

    let mut i: i32 = 0
    while i < assignment_count {
        let a_task_id = assignments[i].task_id
        let a_worker_id = assignments[i].worker_id
        let a_start = assignments[i].start_time
        let a_end = assignments[i].end_time

        let task_idx = find_task_by_id(input, a_task_id)
        let worker_idx = find_worker_by_id(input, a_worker_id)

        if task_idx >= 0 && worker_idx >= 0 {
            check_capability_mismatch(input, task_idx, worker_idx, i, &mut result)
            check_window_conflict(input, worker_idx, a_start, a_end, i, &mut result)
            check_resource_exceeded(input, task_idx, assignments, assignment_count, a_start, a_end, i, &mut result)
            check_dependency_order(input, task_idx, assignments, assignment_count, a_start, i, &mut result)
            check_deadline_exceeded(input, task_idx, a_end, i, &mut result)
            check_overlap_violation(assignments, assignment_count, a_worker_id, a_start, a_end, i, &mut result)
        }
        i = i + 1
    }
    return result
}

fun find_task_by_id(input: ref<ScheduleInput>, task_id: i32) -> i32 {
    let mut i: i32 = 0
    while i < input.task_count {
        if input.tasks[i].id == task_id {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

fun find_worker_by_id(input: ref<ScheduleInput>, worker_id: i32) -> i32 {
    let mut i: i32 = 0
    while i < input.worker_count {
        if input.workers[i].id == worker_id {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

fun check_capability_mismatch(input: ref<ScheduleInput>, task_idx: i32, worker_idx: i32, asgn_idx: i32, result: mutref<ValidationResult>) -> Void {
    let mut missing: i32 = 0
    let mut c: i32 = 0
    while c < input.tasks[task_idx].cap_count {
        let needed = input.tasks[task_idx].caps[c]
        let mut found = false
        let mut w: i32 = 0
        while w < input.workers[worker_idx].cap_count {
            if input.workers[worker_idx].caps[w] == needed {
                found = true
            }
            w = w + 1
        }
        if found == false {
            missing = missing + 1
        }
        c = c + 1
    }
    if missing > 0 && result.violation_count < 32 {
        let vi = result.violation_count
        result.violations[vi].assignment_idx = asgn_idx
        result.violations[vi].kind = ViolationKind.capability_mismatch
        result.violations[vi].missing_cap_count = missing
        result.violation_count = result.violation_count + 1
    }
}

fun check_window_conflict(input: ref<ScheduleInput>, worker_idx: i32, start: i32, end: i32, asgn_idx: i32, result: mutref<ValidationResult>) -> Void {
    let mut w: i32 = 0
    while w < input.workers[worker_idx].unavail_count {
        let ws = input.workers[worker_idx].unavail[w].start
        let we = input.workers[worker_idx].unavail[w].end
        if ws < end && we > start {
            if result.violation_count < 32 {
                let vi = result.violation_count
                result.violations[vi].assignment_idx = asgn_idx
                result.violations[vi].kind = ViolationKind.window_conflict
                result.violations[vi].window_start = ws
                result.violations[vi].window_end = we
                result.violation_count = result.violation_count + 1
            }
        }
        w = w + 1
    }
}

fun check_resource_exceeded(input: ref<ScheduleInput>, task_idx: i32, assignments: ref<[32]Assignment>, assignment_count: i32, start: i32, end: i32, asgn_idx: i32, result: mutref<ValidationResult>) -> Void {
    let mut r: i32 = 0
    while r < input.tasks[task_idx].resource_count {
        let res_id = input.tasks[task_idx].resources[r]
        let mut ri: i32 = 0
        while ri < input.resource_count {
            if input.resources[ri].id == res_id {
                let mut overlap: i32 = 0
                let mut a: i32 = 0
                while a < assignment_count {
                    if assignments[a].start_time < end && assignments[a].end_time > start {
                        let atid = assignments[a].task_id
                        let mut ti: i32 = 0
                        while ti < input.task_count {
                            if input.tasks[ti].id == atid {
                                let mut tr: i32 = 0
                                while tr < input.tasks[ti].resource_count {
                                    if input.tasks[ti].resources[tr] == res_id {
                                        overlap = overlap + 1
                                    }
                                    tr = tr + 1
                                }
                            }
                            ti = ti + 1
                        }
                    }
                    a = a + 1
                }
                if overlap > input.resources[ri].capacity && result.violation_count < 32 {
                    let vi = result.violation_count
                    result.violations[vi].assignment_idx = asgn_idx
                    result.violations[vi].kind = ViolationKind.resource_exceeded
                    result.violations[vi].resource_idx = ri
                    result.violations[vi].count = overlap
                    result.violations[vi].capacity = input.resources[ri].capacity
                    result.violation_count = result.violation_count + 1
                }
            }
            ri = ri + 1
        }
        r = r + 1
    }
}

fun check_dependency_order(input: ref<ScheduleInput>, task_idx: i32, assignments: ref<[32]Assignment>, assignment_count: i32, task_start: i32, asgn_idx: i32, result: mutref<ValidationResult>) -> Void {
    let mut d: i32 = 0
    while d < input.tasks[task_idx].dep_count {
        let dep_id = input.tasks[task_idx].depends_on[d]
        let mut a: i32 = 0
        while a < assignment_count {
            if assignments[a].task_id == dep_id {
                if assignments[a].end_time > task_start && result.violation_count < 32 {
                    let vi = result.violation_count
                    result.violations[vi].assignment_idx = asgn_idx
                    result.violations[vi].kind = ViolationKind.dependency_order
                    result.violations[vi].dep_task_idx = dep_id
                    result.violations[vi].dep_end = assignments[a].end_time
                    result.violations[vi].task_start = task_start
                    result.violation_count = result.violation_count + 1
                }
            }
            a = a + 1
        }
        d = d + 1
    }
}

fun check_deadline_exceeded(input: ref<ScheduleInput>, task_idx: i32, end_time: i32, asgn_idx: i32, result: mutref<ValidationResult>) -> Void {
    let deadline = input.tasks[task_idx].deadline
    if deadline > 0 && end_time > deadline && result.violation_count < 32 {
        let vi = result.violation_count
        result.violations[vi].assignment_idx = asgn_idx
        result.violations[vi].kind = ViolationKind.deadline_exceeded
        result.violations[vi].deadline = deadline
        result.violations[vi].end_time = end_time
        result.violation_count = result.violation_count + 1
    }
}

fun check_overlap_violation(assignments: ref<[32]Assignment>, assignment_count: i32, worker_id: i32, start: i32, end: i32, asgn_idx: i32, result: mutref<ValidationResult>) -> Void {
    let mut a: i32 = 0
    while a < assignment_count {
        if a != asgn_idx && assignments[a].worker_id == worker_id {
            if assignments[a].start_time < end && assignments[a].end_time > start {
                if result.violation_count < 32 {
                    let vi = result.violation_count
                    result.violations[vi].assignment_idx = asgn_idx
                    result.violations[vi].kind = ViolationKind.overlap_violation
                    result.violations[vi].other_task_idx = assignments[a].task_id
                    result.violation_count = result.violation_count + 1
                }
            }
        }
        a = a + 1
    }
}

fun default_viol() -> Violation {
    return Violation {
        assignment_idx: 0,
        kind: ViolationKind.capability_mismatch,
        missing_cap_count: 0,
        window_start: 0,
        window_end: 0,
        resource_idx: 0,
        at_time: 0,
        count: 0,
        capacity: 0,
        dep_task_idx: 0,
        dep_end: 0,
        task_start: 0,
        other_task_idx: 0,
        deadline: 0,
        end_time: 0
    }
}
