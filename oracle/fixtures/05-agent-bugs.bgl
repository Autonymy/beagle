#lang beagle/rkt

(defrecord Task [(id : String) (name : String)])
(defrecord Worker [(id : String) (name : String)])

(defscalar TaskId String)
(defscalar WorkerId String)

(defrecord Assignment [(task-id : TaskId)
                       (worker-id : WorkerId)
                       (start-time : Int)
                       (end-time : Int)])

(defn make-assignment [(task : Task) (worker : Worker)
                       (start : Int) (end : Int)] : Assignment
  (->Assignment (->TaskId (task-id task))
                (->WorkerId (worker-id worker))
                start end))

(defrecord ScheduleFailure [(task-id : String) (reason : String)])

(defunion ScheduleAttempt
  (AttemptSuccess [(assignment : Assignment)])
  (AttemptFailure [(failure : ScheduleFailure)]))

(defrecord AccState [(assignments : (Vec Assignment))
                     (failures : (Vec ScheduleFailure))])

(defn process-attempt [(acc : AccState) (attempt : ScheduleAttempt)] : AccState
  (match attempt
    [(AttemptSuccess a) (->AccState (conj (accstate-assignments acc) a)
                                   (accstate-failures acc))]
    [(AttemptFailure f) (->AccState (accstate-assignments acc)
                                   (conj (accstate-failures acc) f))]))

(def t1 (->Task "task-1" "Oil Change"))
(def w1 (->Worker "worker-1" "Alice"))
(def a1 (make-assignment t1 w1 100 160))

(println (assignment-task-id a1))
(println (assignment-worker-id a1))

(def empty-acc (->AccState [] []))
(def success (->AttemptSuccess a1))
(def failure (->AttemptFailure (->ScheduleFailure "task-2" "no capable worker")))

(def acc1 (process-attempt empty-acc success))
(def acc2 (process-attempt acc1 failure))

(println (count (accstate-assignments acc2)))
(println (count (accstate-failures acc2)))
