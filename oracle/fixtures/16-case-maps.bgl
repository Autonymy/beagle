#lang beagle/rkt

(defn classify-score [(score : Int)] : String
  (cond
    [(>= score 90) "A"]
    [(>= score 80) "B"]
    [(>= score 70) "C"]
    [true "F"]))

(def scores : (Map String Int) {"alice" 95 "bob" 82 "carol" 68})

(defn lookup [(m : (Map String Int)) (k : String)] : String
  (let [v (get m k 0)]
    (str k ": " (classify-score v))))

(println (lookup scores "alice"))
(println (lookup scores "bob"))
(println (lookup scores "carol"))
