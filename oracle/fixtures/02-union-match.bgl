#lang beagle/rkt

(defrecord Circle [(radius : Float)])
(defrecord Rect [(w : Float) (h : Float)])
(defunion Shape Circle Rect)

(defn area [(s : Shape)] : Float
  (match s
    [(Circle r) (* 3.14159 r r)]
    [(Rect w h) (* w h)]))

(def c : Shape (->Circle 5.0))
(def r : Shape (->Rect 3.0 4.0))

(println (area c))
(println (area r))
