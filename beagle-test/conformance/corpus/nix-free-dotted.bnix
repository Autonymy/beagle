#lang beagle/nix
(ns conformance.nix.free-dotted)

;; Ratchet fixture: a dotted name whose ROOT is bound nowhere — not a
;; nix/module formal, a let-binding, or a `nix/with` dynamic scope — is a free
;; variable. It emits `${vendor.id}`, which `nix-instantiate --parse` rejects as
;; an undefined variable (a silent miscompile). The checker rejects it (E021,
;; free-dotted-name) instead, mirroring nix's own scope check. `config` IS a
;; declared formal, so its dotted descent `config.services.*` is accepted; only
;; the free `vendor` root is rejected.
(nix/module [config]
  {:config {:services.foo.extraConfig
              (s config.services.foo.name "=" vendor.id)}})
