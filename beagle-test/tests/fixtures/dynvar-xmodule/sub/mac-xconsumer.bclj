#lang beagle/clj

;; Cross-DIRECTORY + via-MACRO binding of an imported ^:dynamic var — the exact
;; shape fram-2's G-A repro hit (resolver-woven handlers bind imported dynvars
;; through a macro, from a module in another directory). prov.bclj lives in the
;; PARENT dir (resolved via the module-path walk-up) AND the `binding` is produced
;; by macro expansion: `with-v` syntax-quotes (binding [p/*v* …] …). The expander
;; must keep the USE-SITE alias `p/*v*` (NOT qualify it to prov/*v*), so the
;; import set — keyed by the use-site name — still resolves its dynamic-ness.
(require prov :as p)

(defmacro with-v [val body] `(binding [p/*v* ~val] ~body))

(defn u [] :- String (with-v "x" (p/rd)))
