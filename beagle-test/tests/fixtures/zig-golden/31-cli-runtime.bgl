(ns g)
(require clojure.string :as str)
(require babashka.fs :as fs)

(defn norm [s :- String] :- String
  (str/trim (str/lower-case s)))

(defn flags [s :- String] :- Bool
  (and (str/starts-with? s "x")
       (str/ends-with? s "z")
       (str/includes? s "y")
       (not (str/blank? s))))

(defn head3 [s :- String] :- String (subs s 0 3))
(defn tail [s :- String] :- String (subs s 1))

(defn glue [parts :- (Vec String)] :- String (str/join "," parts))
(defn fix [s :- String] :- String (str/replace s "a" "b"))
(defn lines [s :- String] :- (Vec String) (str/split-lines s))

(defn dir [p :- String] :- String (fs/parent p))
(defn under [a :- String b :- String] :- String (fs/path a b))
(defn read-it [p :- String] :- String (slurp p))
(defn write-it [p :- String s :- String] :- Nil (spit p s))
