#lang beagle/sql
(ns test.sql.subquery)

;; EXISTS subquery + IN subquery.
(select [name email]
  (from customers :as c)
  (where (and (exists (select [1]
                        (from orders :as o)
                        (where (= o.customer_id c.id))))
              (in c.id (select [customer_id]
                         (from premium_members))))))
